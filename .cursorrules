

# ============================================================================
# .cursorrules — Graph Cognitive Engine
# ============================================================================
# 20 contracts. Violate any → revert and ask.
# ============================================================================


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LAYER 1 — CHASSIS BOUNDARY (contracts 1–5)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CONTRACT 1: SINGLE INGRESS
# The only HTTP surface is POST /v1/execute and GET /v1/health.
# Engine NEVER imports FastAPI, Starlette, or any HTTP library.
# Engine NEVER creates routes, APIRouter, or app factories.

# CONTRACT 2: HANDLER INTERFACE
# Engine exposes action handlers only:
#   async def handle_<action>(tenant: str, payload: dict) -> dict
# Register in engine/handlers.py via:
#   chassis.router.register_handler("match", handle_match)
# handlers.py is the ONLY file that imports chassis modules.

# CONTRACT 3: TENANT ISOLATION
# Tenant is resolved BY the chassis (5-level: header → subdomain → key prefix → envelope → default).
# Engine receives tenant as a string argument. Engine NEVER resolves tenant.
# Every Neo4j query scopes to tenant database. No cross-tenant reads.

# CONTRACT 4: OBSERVABILITY IS INHERITED
# Engine NEVER configures structlog, Prometheus, or logging handlers.
# Chassis provides: structured JSON logging, trace_id propagation, /metrics endpoint.
# Engine uses: structlog.get_logger(__name__) — nothing else.

# CONTRACT 5: INFRASTRUCTURE IS TEMPLATE
# Engine NEVER creates: Dockerfile, docker-compose, CI pipeline, Terraform modules.
# All exist in l9-template. Engine adds engine-specific env vars to .env.template only.


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LAYER 2 — PACKET PROTOCOL (contracts 6–8)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CONTRACT 6: PACKETENVELOPE IS THE ONLY DATA CONTAINER
# Every inter-service payload is a PacketEnvelope.
# inflate_ingress() at boundary entry. deflate_egress() at boundary exit.
# Engine code between boundaries works with typed dicts/Pydantic — never raw envelopes.

# CONTRACT 7: IMMUTABILITY + CONTENT HASH
# PacketEnvelope is frozen (Pydantic frozen=True). Mutations create new packets via .derive().
# content_hash (SHA-256 of canonical payload) is a UNIQUE DB constraint.
# Design all writes for idempotency — duplicate content_hash is silently rejected.

# CONTRACT 8: LINEAGE + AUDIT
# Every derived packet sets parent_id, root_id, increments generation.
# hop_trace is append-only: each node that touches a packet adds a HopEntry.
# delegation_chain carries scoped authorization through multi-hop flows.
# Engine NEVER bypasses lineage — all new packets come from .derive() or PacketEnvelope.create().


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LAYER 3 — SECURITY (contracts 9–11)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CONTRACT 9: CYPHER INJECTION PREVENTION
# All Neo4j labels and relationship types MUST pass sanitize_label() before interpolation.
# Regex: ^[A-Za-z_][A-Za-z0-9_]*$
# Cypher VALUES always use parameterized queries ($batch, $query).
# Only labels/types are interpolated — after sanitization.

# CONTRACT 10: PROHIBITED FACTORS
# Compliance fields (race, ethnicity, religion, gender, age, disability, familial_status,
# national_origin) are blocked at compile-time during gate validation.
# If a domain spec references a prohibited field → gate compilation fails, not a runtime error.
# audit_on_violation: true — every blocked attempt is logged.

# CONTRACT 11: PII HANDLING
# PII fields declared in domain spec compliance.pii.fields.
# Handling mode per domain: hash | encrypt | redact | tokenize.
# Encryption key source: env | vault | kms (declared in spec, never hardcoded).
# Engine NEVER logs PII values. structlog filters are set by chassis.


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LAYER 4 — ENGINE ARCHITECTURE (contracts 12–16)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CONTRACT 12: DOMAIN SPEC IS THE SOURCE OF TRUTH
# All matching behavior comes from {domain_id}_domain_spec.yaml.
# DomainPackLoader (engine/config/loader.py) reads YAML → DomainConfig (Pydantic).
# Every downstream module consumes DomainConfig — never raw YAML, never raw dicts.
# Domain specs are untrusted input (uploaded via admin endpoints) → validate everything.

# CONTRACT 13: GATE-THEN-SCORE ARCHITECTURE
# Matching is two-phase: gates (hard filter) → scoring (soft rank).
# All gate logic compiles to Cypher WHERE clauses — zero post-filtering in Python.
# All scoring dimensions compile to a single WITH/ORDER BY clause — no iterative scoring.
# 10 gate types: range, threshold, boolean, composite, enum_map, exclusion,
#   self_range, freshness, temporal_range, traversal.
# 9 scoring computations: geo_decay, log_normalized, community_match, inverse_linear,
#   candidate_property, weighted_rate, price_alignment, temporal_proximity, custom_cypher.

# CONTRACT 14: NULL SEMANTICS ARE DETERMINISTIC
# Every gate declares null_behavior: pass | fail.
# pass → wraps predicate in (candidate.prop IS NULL OR <predicate>).
# fail → NULL candidate is rejected.
# This is per-gate, not global. The compiler handles it — callers don't.

# CONTRACT 15: BIDIRECTIONAL MATCHING
# Gates with invertible: true swap candidate_prop ↔ query_param when match direction reverses.
# Gates with match_directions: [specific] only fire for those directions.
# Scoring dimensions similarly scope to match_directions.
# The compiler handles inversion — gate implementations are direction-unaware.

# CONTRACT 16: FILE STRUCTURE IS FIXED
# engine/handlers.py      → ONLY chassis bridge (register_all)
# engine/config/           → Domain spec schema + loader + settings + units
# engine/gates/            → Gate compiler + null semantics + registry + types/
# engine/scoring/          → Scoring assembler
# engine/traversal/        → Traversal assembler + resolver
# engine/sync/             → Sync generator
# engine/gds/              → GDS scheduler (APScheduler from spec.gds_jobs)
# engine/graph/            → Neo4j async driver wrapper
# engine/compliance/       → Prohibited factors + PII + audit
# engine/packet/           → PacketEnvelope bridge (chassis_contract.py)
# engine/utils/            → safe_eval, security (sanitize_label)
# chassis/                 → Thin chassis adapter (actions.py)
# domains/                 → {domain_id}_domain_spec.yaml per vertical
# Do NOT create new top-level directories without architectural approval.


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LAYER 5 — TESTING + QUALITY (contracts 17–18)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CONTRACT 17: TEST REQUIREMENTS
# Unit tests: gate compilation, scoring math, parameter resolution, null semantics per gate.
# Integration tests: testcontainers-neo4j — do NOT mock the Neo4j driver.
# Compliance tests: verify prohibited factors are blocked at compile time.
# Performance: <200ms p95 match latency.
# Validation: compiled Cypher for plasticos_spec.yaml must match hand-verified reference output.

# CONTRACT 18: L9_META ON EVERY FILE
# Every tracked file carries an L9_META header (schema version 1).
# Fields: l9_schema, origin, engine, layer, tags, owner, status.
# Format varies by filetype (YAML comment, HTML comment, Python docstring, JSON key, TOML table).
# Injected by tools/l9_meta_injector.py — not manually. Run it, commit, done.


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LAYER 6 — GRAPH INTELLIGENCE (contracts 19–20)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CONTRACT 19: GDS JOBS ARE DECLARATIVE
# Graph Data Science algorithms (Louvain, similarity, etc.) are declared in spec.gds_jobs.
# Schedule type: cron | manual. Projections declare node_labels + edge_types.
# Scheduler reads the spec and creates APScheduler jobs — no hardcoded algorithm calls.
# GDS write targets (write_property, write_to, write_edge) are spec-driven.

# CONTRACT 20: KGE EMBEDDINGS (CompoundE3D)
# Model: CompoundE3D, 256-dim default. Training relations from domain spec ontology.edges.
# Beam search (width=10, depth=3) for link prediction.
# Ensemble strategy: weighted_average | rank_aggregation | mixture_of_experts.
# KGE scores are a scoring dimension — they feed into the same WITH clause as all others.
# Vector index stored in Neo4j (cosine similarity). Embeddings are domain-specific, never shared cross-tenant.


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CODE STYLE + CONVENTIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# LANGUAGE: Python 3.12+, async/await for all I/O (Neo4j, PostgreSQL, Redis).
# TYPE HINTS: Every function signature, class attribute, ambiguous variable.
# MODELS: Pydantic v2 BaseModel (frozen where appropriate) for all structured data.
# FORMATTER: ruff format (Black-compatible, 88-char line length). Run before commit.
# LINTER: ruff check + mypy --strict engine/
# LOGGING: structlog.get_logger(__name__). Include tenant, trace_id, action in context.
# NAMING: snake_case everywhere. No Pydantic Field(alias=...). YAML keys = Python field names.
#
# RUFF PATTERNS THAT CAUSE NOISE (write code that avoids them):
#
#   Exceptions → always assign message to variable first:
#     BAD:  raise ValueError(f"invalid {x}")
#     GOOD: msg = f"invalid {x}"; raise ValueError(msg)
#     (prevents EM101, EM102 — duplicated traceback lines)
#
#   Nullable params → explicit union, never implicit Optional:
#     BAD:  def f(x: str = None)
#     GOOD: def f(x: str | None = None)
#     (prevents RUF013)
#
#   Mutable class defaults → always annotate ClassVar:
#     BAD:  class C: items = []
#     GOOD: class C: items: ClassVar[list[str]] = []
#     (prevents RUF012 — Pydantic frozen models are exempt)
#
#   Datetime → always timezone-aware:
#     BAD:  datetime.now()
#     GOOD: datetime.now(tz=UTC)
#     (prevents DTZ005 — only suppress with noqa + comment for scheduler local time)
#
#   Singletons → module pattern, not global keyword:
#     BAD:  global _driver; _driver = ...
#     GOOD: _driver: GraphDriver | None = None  (module-level, set via init function)
#     (prevents PLW0603)
#
#   Many args → group into dataclass/TypedDict when >8:
#     Threshold set to max-args=8 (not default 5). Audit/compliance APIs need 6-8.
#     Beyond 8 → use @dataclass param object.
#     (prevents PLR0913)
#
#   Branches → extract helpers when >15:
#     Threshold set to max-branches=15 (not default 12). Gate compiler is inherently branchy.
#     Beyond 15 → extract sub-functions.
#     (prevents PLR0912)
#
#   Magic values → named constants in engine/, literals OK in tests/:
#     BAD (in engine):  if score > 0.85
#     GOOD (in engine):  MATCH_THRESHOLD = 0.85; if score > MATCH_THRESHOLD
#     (PLR2004 is per-file-ignored in tests/ and config/)


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# KEY COMMANDS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# make setup             → Install deps, pre-commit hooks, verify Neo4j
# make dev               → docker-compose (app + Neo4j + Redis + Prometheus + Grafana)
# make test              → Full pytest suite (unit + integration + compliance)
# make test-unit         → Gate compilation, scoring math, parameter resolution
# make test-integration  → testcontainers-neo4j full pipeline
# make lint              → ruff check + ruff format --check + mypy --strict engine/
# make lint-fix          → ruff check --fix + ruff format .
# make cypher-lint       → Scan generated Cypher for injection vectors
# make gds-trigger JOB=louvain DOMAIN=plasticos  → Manual GDS job trigger
# make build             → Docker image
# make deploy ENV=staging → Railway/ArgoCD deploy


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# IMPORT PATTERNS (canonical — do not deviate)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

