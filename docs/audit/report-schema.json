{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "L9 Audit Report",
  "type": "object",
  "required": [
    "audit_id",
    "timestamp",
    "mode",
    "total_findings",
    "findings"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{12}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": [
        "full",
        "incremental",
        "category"
      ]
    },
    "categories_scanned": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "total_findings": {
      "type": "integer",
      "minimum": 0
    },
    "by_severity": {
      "type": "object",
      "properties": {
        "P0": {
          "type": "integer"
        },
        "P1": {
          "type": "integer"
        },
        "P2": {
          "type": "integer"
        },
        "P3": {
          "type": "integer"
        }
      }
    },
    "by_category": {
      "type": "object",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "estimated_fix_hours": {
      "type": "integer",
      "minimum": 0
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "severity",
          "title",
          "file",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]{2,4}-\\d{3}$"
          },
          "category": {
            "type": "string"
          },
          "subcategory": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "title": {
            "type": "string",
            "maxLength": 200
          },
          "file": {
            "type": "string"
          },
          "line_start": {
            "type": "integer",
            "minimum": 0
          },
          "line_end": {
            "type": "integer",
            "minimum": 0
          },
          "description": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "adr_violations": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^ADR-\\d{4}$"
            }
          },
          "fix_effort_hours": {
            "type": "integer",
            "minimum": 1
          },
          "blast_radius": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fix_strategy": {
            "type": "string"
          },
          "code_before": {
            "type": "string"
          },
          "code_after": {
            "type": "string"
          },
          "test_snippet": {
            "type": "string"
          }
        }
      }
    }
  }
}